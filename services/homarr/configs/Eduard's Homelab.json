            "customCss": ":root{--tokyo-night-bg:#1a1b26;--tokyo-night-bg-dark:#16161e;--tokyo-night-fg:#c0caf5;--tokyo-night-blue:#7aa2f7;--tokyo-night-cyan:#7dcfff;--tokyo-night-purple:#bb9af7;--tokyo-night-green:#9ece6a;--tokyo-night-red:#f7768e;--tokyo-night-orange:#ff9e64;--tokyo-night-yellow:#e0af68}body{background:var(--tokyo-night-bg-dark)!important;color:var(--tokyo-night-fg)!important}.mantine-AppShell-main{background:var(--tokyo-night-bg-dark)!important}.mantine-Paper-root{background:var(--tokyo-night-bg)!important;border:1px solid rgba(122,162,247,0.2)!important;transition:all 0.3s ease!important}.mantine-Paper-root:hover{border-color:var(--tokyo-night-blue)!important;box-shadow:0 4px 20px rgba(122,162,247,0.3)!important;transform:translateY(-2px)!important}.mantine-Title-root{color:var(--tokyo-night-blue)!important;font-weight:600!important}.mantine-Text-root{color:var(--tokyo-night-fg)!important}.mantine-Badge-root{background:var(--tokyo-night-green)!important}.mantine-TextInput-input{background:var(--tokyo-night-bg)!important;border-color:rgba(122,162,247,0.3)!important;color:var(--tokyo-night-fg)!important}.mantine-TextInput-input:focus{border-color:var(--tokyo-night-blue)!important}.mantine-Button-root{background:var(--tokyo-night-blue)!important;color:var(--tokyo-night-bg-dark)!important}.mantine-Button-root:hover{background:var(--tokyo-night-cyan)!important}::-webkit-scrollbar{width:10px}::-webkit-scrollbar-track{background:var(--tokyo-night-bg-dark)}::-webkit-scrollbar-thumb{background:var(--tokyo-night-blue);border-radius:5px}::-webkit-scrollbar-thumb:hover{background:var(--tokyo-night-cyan)}",
